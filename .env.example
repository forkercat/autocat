# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Comma-separated list of allowed Telegram user IDs (security: only these users can interact)
ALLOWED_TELEGRAM_USERS=

# Claude model to use: claude-sonnet-4-6 or claude-opus-4-6
CLAUDE_MODEL=claude-sonnet-4-6

# Assistant name
ASSISTANT_NAME=AutoCat

# Timezone for scheduled tasks (e.g., America/Los_Angeles, America/New_York, Asia/Shanghai)
TIMEZONE=America/Los_Angeles

# Data directory (default: ./data)
DATA_DIR=./data

# Max concurrent Claude sessions
MAX_CONCURRENT_SESSIONS=2

# Session idle timeout in seconds (default: 300)
SESSION_IDLE_TIMEOUT=300

# Daily session reset hour (0-23, in TIMEZONE)
DAILY_RESET_HOUR=4

# Google Workspace CLI integration (requires `gws` installed and authenticated)
# Enables /gmail, /calendar, /gtasks commands
GWS_ENABLED=false

# Enable debug logging
DEBUG=false

# Metrics/health HTTP server address (default: :9090)
# Endpoints: GET /metrics (JSON), GET /health
METRICS_ADDR=:9090
